```gitignore
# =========================
# Dependencies
# =========================
node_modules/

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Runtime Data
# =========================
pids/
*.pid
*.seed
*.pid.lock

# =========================
# Build Output
# =========================
dist/
build/
.next/
out/

# =========================
# Coverage
# =========================
coverage/
.nyc_output/

# =========================
# Cache
# =========================
.cache/
.parcel-cache/
.vite/
.eslintcache

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# Temporary Files
# =========================
tmp/
temp/

# =========================
# Package Manager
# =========================
package-lock.json
yarn.lock
pnpm-lock.yaml

# =========================
# Firebase / Deployment (optional)
# =========================
.firebase/
.vercel/
.netlify/

# =========================
# Local Database Files
# =========================
*.sqlite
*.db

# =========================
# Miscellaneous
# =========================
*.tgz
```
